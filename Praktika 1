
<!DOCTYPE html>
<html lang="kaa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Miyweler Tapsırması</title>
    <style>
        /* CSS stilleri usı jerde */
        body {
            font-family: 'Times New Roman', serif;
            background-color:blakc;
            padding-top: 50px;
        }

        .container {
            background-color: white;
            padding: 30px;
            width: 350px;
            border: 1px;
            box-shadow: 0 4px 10px;
        }

        .link-top {
            color: blue;
            text-decoration: underline;
            font-size: 18px;
            display: block;
            margin-bottom: 20px;
        }

        h1 {
            font-size: 48px;
            margin: 0 0 20px 0;
            font-weight: bold;
        }

        .list {
            padding: 0;
            margin: 0 0 30px 0;
        }

        .list li {
            font-size: 24px;
            margin-bottom: 15px;
        }

        .btn-group {
            
            
            align-items: center;
        }

        .btn-sebet {
            background-color:grenn;
            color: black;
            border: 2px solid black;
            padding: 8px 20px;
            font-weight: bold;
            font-size: 16px;
        }

        .btn-satip {
            background-color: black;
            color: white;
            border: 1px;
            padding: 8px 20px;
            font-size: 16px;
           
        }

        .footer-text {
            margin-top: 20px;
            font-size: 18px;
            color: #333;
        }
    </style>
</head>
<body>

    <div class="container">
        <a href="#" class="link-top">Uzın nan satıp alıw</a>
        
        <h1>Miyweler</h1>
        
        <ul class="list">
            <li>Alma</li>
            <li>Pomidor</li>
            <li>Banan</li>
        </ul>

        <div class="btn-group">
            <button class="btn-sebet">SEBET</button>
            <button class="btn-satip">SATIP ALIW</button>

</body>
</html
